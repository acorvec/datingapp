    #mainContent
        - let altText = "A picture of " + user.name;
        img#mainPicture(src="/" + user.mainImage alt=altText)
        h1#pageTitle= "Other Singles"

        - const calculatePronoun = (gender) => {
        -   if (gender === "male") return "he's";
        -   else if (gender === "female") return "she's";
        -   else return "they're";
        - };
        - const pronoun = calculatePronoun(user.gender);
        p#pageDescription
            span Want to give up on #{user.name}? 
            span We think #{pronoun} great, but we also have other singles!

        each other in otherUsers
            - altText = "A picture of " + other.name
            img#otherPicture(src="/" + other.mainImage alt=altText)
            a.otherLink(href="/user/" + other.fileName)
                span.otherName #{other.name}
                span.otherAge , #{other.age}
